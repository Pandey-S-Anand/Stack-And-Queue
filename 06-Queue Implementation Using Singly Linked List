public class Queue {
    // Underlying data structure used to implement the queue
    private SinglyLinkedList singlyLinkedList;

    Queue() {
        singlyLinkedList = new SinglyLinkedList();
    }

    // Returns true if the queue has no elements
    boolean isEmpty() {
        return singlyLinkedList.isEmpty();
    }

    //Inserts an element at the rear of the queue.
    void enqueue(int data) {
        singlyLinkedList.append(data);
    }

    //Removes and returns the element from the front of the queue.
    int dequeue() {
        return singlyLinkedList.removeFromFront();
    }

    //Returns the element at the front of the queue
    int front() {
        return singlyLinkedList.getFront();
    }
}

/**
 * Node class representing one element in the linked list.
 *
 * Each node stores:
 * data ? value of the element
 * next ? pointer to the next node
 */
class Node {
    int data;
    Node next;

    public Node(int data) {
        this.data = data;
        this.next = null;
    }
}

/**
 * Singly Linked List implementation used internally by the queue.
 *
 * head ? front of the queue
 * tail ? rear of the queue
 */
class SinglyLinkedList {
    private Node head;
    private Node tail;

    SinglyLinkedList() {
        this.head = null;
        this.tail = null;
    }

    /**
     * Appends a node at the end of the linked list.
     *
     * This represents the enqueue operation of the queue.
     */
    public void append(int data) {
        Node node = new Node(data);

        // If the list is empty, new node becomes both head and tail
        if (head == null) {
            head = tail = node;
        } else {
            // Attach new node after current tail
            tail.next = node;
            // Update tail pointer
            tail = tail.next;
        }
    }

    /**
     * Removes the node from the front of the list.
     *
     * This represents the dequeue operation of the queue.
     */
    public int removeFromFront() {
        // List is empty
        if (isEmpty()) {
            return -1;
        }

        Node removedNode = head;

        // If only one node exists
        if (head == tail) {
            head = tail = null;
        } else {
            // Move head to the next node
            head = head.next;
            // Disconnect removed node
            removedNode.next = null;
        }

        return removedNode.data;
    }

    //Returns the front element without removing it.
    public int getFront() {
        // List is empty
        if (isEmpty()) {
            return -1;
        }

        return head.data;
    }

    //Returns true if the list is empty.
    public boolean isEmpty() {
        return head == null;
    }
}
