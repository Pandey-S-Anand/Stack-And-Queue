public class Solution {
    class Queue {
        /**
         * front => index of the element that will be removed next
         * rear  => index of the most recently inserted element
         */
        int front, rear;

        // Underlying array used to store queue elements
        int[] arr;

        Queue() {
            front = -1;
            rear = -1;

            /**
             * Large fixed capacity to accommodate the maximum
             * number of queue operations expected in the problem.
             */
            arr = new int[100001];
        }

        //Inserts a new element at the rear of the queue.
        public void enqueue(int data) {
            // Overflow condition
            if (isFull()) {
                return;
            }
            // First insertion in the queue
            if (isEmpty()) {
                front = rear = 0;
            } else {
                // Move rear forward for the next insertion
                rear++;
            }

            arr[rear] = data;
        }

        // Removes and returns the element at the front of the queue.
        public int dequeue() {
            // Underflow condition
            if (isEmpty()) {
                return -1;
            }

            int removedElement = arr[front];

            /**
             * If this was the last element in the queue,
             * reset the queue to the empty state.
             */
            if (front == rear) {
                front = rear = -1;
            } else {
                // Move front forward to the next element
                front++;
            }

            return removedElement;
        }

        // Checks whether the queue is empty.
        public boolean isEmpty() {
            return front == -1 && rear == -1;
        }

        // Check if the queue is full
        public boolean isFull() {
            return rear == arr.length - 1;
        }

        // Get the size of the queue (number of elements)
        public int getSize() {
            if (isEmpty()) {
                return 0;
            }
            return (rear - front + 1);
        }

        // Peek the front element of the queue
        public int peek() {
            if (isEmpty()) {
                return -1;
            }
            return arr[front];
        }
    }
}
