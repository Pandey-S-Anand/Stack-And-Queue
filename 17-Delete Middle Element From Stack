//Recursive Approach

//Intuitive implementation

public class Solution {
    public static void deleteMiddle(Stack<Integer> stack, int n) {
        // Get the current size of the stack
        int stackSize = stack.size();

        /**
         * Determine the index of the middle element.
         *
         * If the stack size is odd:
         *      middleIndex = size / 2
         *
         * If the stack size is even:
         *      remove the lower middle element
         *      middleIndex = (size - 1) / 2
         */
        int middleIndex = (stackSize % 2 != 0) ? stackSize / 2 : (stackSize - 1) / 2;

        // Start recursive deletion
        deleteMiddleElement(stack, middleIndex);
    }

    private static void deleteMiddleElement(Stack<Integer> stack, int index) {
        // Base case: middle element reached
        if (index == 0) {
            stack.pop();
            return;
        }

        // Temporarily remove the top element
        int topElement = stack.pop();

        // Recursively move toward the middle element
        deleteMiddleElement(stack, index - 1);

        // Restore the removed element
        stack.push(topElement);
    }
}


//Concise implementation

public class Solution {
    public static void deleteMiddle(Stack<Integer> stack, int n) {
        deleteMiddleElement(stack, (stack.size() - 1) / 2);
    }

    private static void deleteMiddleElement(Stack<Integer> stack, int index) {
        if (index == 0) {
            stack.pop();
            return;
        }

        int topElement = stack.pop();

        deleteMiddleElement(stack, index - 1);

        stack.push(topElement);
    }
}


//Iterative Approach

public class Solution {
    /**
     *
     * Middle index calculation:
     *
     *      middleIndex = (size - 1) / 2
     *
     * This ensures:
     * - For odd-sized stacks → exact middle element is removed
     * - For even-sized stacks → the lower middle element is removed
     *
     * Example:
     *
     * Original stack (top → bottom)
     *      5
     *      4
     *      3
     *      2
     *      1
     *
     * Stack size = 5
     * middleIndex = (5 - 1) / 2 = 2
     *
     * Elements moved to auxStack:
     *      5
     *      4
     *
     * Remove middle element:
     *      3
     *
     * Restore elements:
     *      5
     *      4
     *      2
     *      1
     *
     * Final stack (top → bottom)
     *      5
     *      4
     *      2
     *      1
     *
     */
    public static void deleteMiddle(Stack<Integer> stack, int n) {
        // Calculate index of the middle element
        int middleIndex = (stack.size() - 1) / 2;

        // Auxiliary stack used to temporarily hold elements
        Stack<Integer> auxStack = new Stack<>();

        // Move elements above the middle element into auxStack
        while (middleIndex != 0) {
            auxStack.push(stack.pop());
            middleIndex--;
        }

        // Remove the middle element
        stack.pop();

        // Restore the remaining elements
        while (!auxStack.isEmpty()) {
            stack.push(auxStack.pop());
        }
    }
}
