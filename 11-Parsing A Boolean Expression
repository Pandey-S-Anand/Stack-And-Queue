//Intuitive implementation

class Solution {
    public boolean parseBoolExpr(String expression) {
        // Stack used to process the boolean expression
        Deque<Character> stack = new ArrayDeque<>();

        // Traverse the entire expression
        for (int i = 0; i < expression.length(); i++) {
            char ch = expression.charAt(i);

            // Commas are just separators between operands, ignore them
            if (ch == ',') {
                continue;
            }

            /**
             * Push the current character to the stack if it is not ')'.
             * Includes operators ('&', '|', '!'), operands ('t', 'f'), and '('.
             */
            if (ch != ')') {
                stack.push(ch);
            } else if (ch == ')') { // If ')' is encountered, it indicates the end of a subexpression
                // List to collect all operands inside the current subexpression
                List<Character> operands = new ArrayList<>();

                // Extract all operands of the current subexpression by popping elements until '(' is encountered
                while (stack.peek() != '(') {
                    operands.add(stack.pop());
                }

                // Remove '(' from the stack
                stack.pop();

                // The operator ('!', '&', '|') will be just before '('
                char operator = stack.pop();

                // Evaluate the subexpression using the operands and operator
                char result = evaluateExpression(operands, operator);

                // Push the result back onto the stack for further processing
                stack.push(result);
            }
        }

        // The final result will be the only element left on the stack
        return stack.peek() == 't';
    }

    private char evaluateExpression(List<Character> operands, char operator) {
        switch (operator) {
            case '|': // Logical OR
                // Return 't' if any operand is 't', otherwise return 'f'
                for (char ch : operands) {
                    if (ch == 't') {
                        return 't';
                    }
                }

                return 'f';

            case '&': // Logical AND
                // Return 'f' if any operand is 'f', otherwise return 't'
                for (char ch : operands) {
                    if (ch == 'f') {
                        return 'f';
                    }
                }

                return 't';

            default: // case '!': Logical NOT (expects exactly one operand)
                return operands.get(0) == 'f' ? 't' : 'f';
        }
    }
}



//Optimal Implementation

class Solution {
    public boolean parseBoolExpr(String expression) {
        Deque<Character> stack = new ArrayDeque<>();

        for (int i = 0; i < expression.length(); i++) {
            char ch = expression.charAt(i);

            if (ch == ',') {
                continue;
            }

            if (ch != ')') {
                stack.push(ch);
            } else {
                // Track whether the operands contain true or false
                boolean hasTrue = false;
                boolean hasFalse = false;

                while (stack.peek() != '(') {
                    char operand = stack.pop();

                    if (operand == 't') {
                        hasTrue = true;
                    } else if (operand == 'f') {
                        hasFalse = true;
                    }
                }

                stack.pop();

                char operator = stack.pop();

                char result = evaluateExpression(hasTrue, hasFalse, operator);

                stack.push(result);
            }
        }

        return stack.peek() == 't';
    }


    /**
     * Evaluates the boolean subexpression based on the operator.
     *
     * hasTrue  → whether at least one operand was 't'
     * hasFalse → whether at least one operand was 'f'
     */
    private char evaluateExpression(boolean hasTrue, boolean hasFalse, char operator) {

        switch (operator) {
            // OR: true if any operand is true
            case '|':
                return hasTrue ? 't' : 'f';

            // AND: false if any operand is false
            case '&':
                return hasFalse ? 'f' : 't';

            /*
             * NOT operator is unary in the expression grammar,
             * meaning it always has exactly one operand.
             *
             * If the operand was true → result becomes false
             * If the operand was false → result becomes true
             */
            default: // '!'
                return hasTrue ? 'f' : 't';
        }
    }
}
