class Solution {
    public long subArrayRanges(int[] arr) {
        long totalMinSum = 0;
        long totalMaxSum = 0;

        int[] nextGreaterOrEqualIndices = findNextGreaterOrEqualIndices(arr);
        int[] nextSmallerOrEqualIndices = findNextSmallerOrEqualIndices(arr);

        Deque<Integer> stack1 = new ArrayDeque<>();
        Deque<Integer> stack2 = new ArrayDeque<>();

        for (int i = 0; i < arr.length; i++) {
            while (!stack1.isEmpty() && arr[stack1.peek()] >= arr[i]) {
                stack1.pop();
            }

            while (!stack2.isEmpty() && arr[stack2.peek()] <= arr[i]) {
                stack2.pop();
            }

            int prevSmallerIndex = stack1.isEmpty() ? -1 : stack1.peek();

            int prevGreaterIndex = stack2.isEmpty() ? -1 : stack2.peek();

            long minContributionCount = (i - prevSmallerIndex) * (long) (nextSmallerOrEqualIndices[i] - i);

            long maxContributionCount = (i - prevGreaterIndex) * (long) (nextGreaterOrEqualIndices[i] - i);

            totalMinSum += arr[i] * minContributionCount;
            totalMaxSum += arr[i] * maxContributionCount;

            stack1.push(i);
            stack2.push(i);
        }

        return totalMaxSum - totalMinSum;
    }

    private int[] findNextGreaterOrEqualIndices(int[] arr) {
        Deque<Integer> stack = new ArrayDeque<>();

        int[] nextGreaterOrEqualIndices = new int[arr.length];

        for (int i = arr.length - 1; i >= 0; i--) {
