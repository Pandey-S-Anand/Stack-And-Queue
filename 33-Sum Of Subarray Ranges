//Bruteforce Approach

class Solution {
    public long subArrayRanges(int[] arr) {
        long totalRangeSum = 0;

        //Generate all possible subarrays using two loops (start, end).
        for (int start = 0; start < arr.length; start++) {
            for (int end = start; end < arr.length; end++) {
                // Compute range (max - min) for current subarray, add this difference (range) to the total sum.
                totalRangeSum += getRangeOfSubarray(arr, start, end);
            }
        }

        return totalRangeSum;
    }

    private int getRangeOfSubarray(int[] arr, int start, int end) {
        int max = arr[start];
        int min = arr[start];

        for (int i = start; i <= end; i++) {
            max = Math.max(max, arr[i]);
            min = Math.min(min, arr[i]);
        }

        return max - min;
    }
}


//Improved Approach

class Solution {
    /*
    * Instead of recomputing max and min for every subarray,
    * we extend the subarray and update max/min incrementally.
    */
    public long subArrayRanges(int[] arr) {
        long totalRangeSum = 0;

        for (int start = 0; start < arr.length; start++) {
            int max = arr[start];
            int min = arr[start];
            for (int end = start; end < arr.length; end++) {
                max = Math.max(max, arr[end]);
                min = Math.min(min, arr[end]);
                totalRangeSum += (max - min);
            }
        }

        return totalRangeSum;
    }
}



