// Bruteforce Approach

class Solution {
    public int largestRectangleArea(int[] heights) {
        int maxArea = 0;

        for (int i = 0; i < heights.length; i++) {
            int height = heights[i];

            // Determine the width using the nearest smaller elements
            int width = findNextSmallerIndex(heights, i) - findPreviousSmallerIndex(heights, i) - 1;
            int area = height * width;

            maxArea = Math.max(maxArea, area);
        }

        return maxArea;
    }

    /**
     * Finds the index of the nearest smaller element
     * to the left of the given index.
     *
     * If no such element exists, return -1.
     */
    private int findPreviousSmallerIndex(int[] heights, int index) {
        for (int i = index - 1; i >= 0; i--) {
            if (heights[i] < heights[index]) {
                return i;
            }
        }

        return -1; // No smaller element on the left
    }

    /**
     * Finds the index of the nearest smaller element
     * to the right of the given index.
     *
     * If no such element exists, return heights.length
     * to indicate that the rectangle can extend to the
     * end of the histogram.
     */
    private int findNextSmallerIndex(int[] heights, int index) {
        for (int i = index + 1; i < heights.length; i++) {
            if (heights[i] < heights[index]) {
                return i;
            }
        }

        return heights.length; // No smaller element on the right
    }
}


//Optimal Approach (Using monotonic increasing stack)

//Naive Implementation

class Solution {
    /*
     * Improvement over the brute force approach
     * -----------------------------------------
     * In the brute force solution, for every bar we scanned the entire left
     * and right side to find the nearest smaller elements.
     *
     * To optimize this, we precompute two arrays:
     *
     * 1. prevSmallerIndices[i] → index of the nearest smaller bar to the left
     * 2. nextSmallerIndices[i] → index of the nearest smaller bar to the right
     *
     * These arrays can be computed in O(n) time using a Monotonic Stack.
     *
     * Once these boundaries are known, the maximum rectangle that can be formed
     * using heights[i] as the limiting height is determined by the width between
     * these two smaller bars.
     *
     * width = nextSmallerIndices[i] - prevSmallerIndices[i] - 1
     *
     * area = heights[i] * width
     *
     * We compute this area for every bar and track the maximum value.
     *
     * Why do we store indices in the stack instead of values?
     * -------------------------------------------------------
     * In this problem, we need the exact indices of the nearest smaller
     * elements to calculate the width of the rectangle.
     *
     * Since the rectangle width depends on the distance between indices,
     * storing only values would not allow us to determine this distance.
     */
    public int largestRectangleArea(int[] heights) {
        int maxArea = 0;

        int[] prevSmallerIndices = findPreviousSmallerIndices(heights);
        int[] nextSmallerIndices = findNextSmallerIndices(heights);

        for (int i = 0; i < heights.length; i++) {
            int height = heights[i];

            int width = nextSmallerIndices[i] - prevSmallerIndices[i] - 1;

            int area = height * width;

            maxArea = Math.max(maxArea, area);
        }

        return maxArea;
    }

    private int[] findPreviousSmallerIndices(int[] heights) {
        int[] prevSmallerIndices = new int[heights.length];
        Deque<Integer> stack = new ArrayDeque<>();

        for (int i = 0; i < heights.length; i++) {
            while (!stack.isEmpty() && heights[stack.peek()] >= heights[i]) {
                stack.pop();
            }

            prevSmallerIndices[i] = stack.isEmpty() ? -1 : stack.peek();

            stack.push(i);
        }

        return prevSmallerIndices;
    }

    private int[] findNextSmallerIndices(int[] heights) {
        int[] nextSmallerIndices = new int[heights.length];
        Deque<Integer> stack = new ArrayDeque<>();

        for (int i = heights.length - 1; i >= 0; i--) {

            while (!stack.isEmpty() && heights[stack.peek()] >= heights[i]) {
                stack.pop();
            }

            nextSmallerIndices[i] = stack.isEmpty() ? heights.length : stack.peek();

            stack.push(i);
        }

        return nextSmallerIndices;
    }
}



//Good Implementation

class Solution {
    /*
    * Further Improvement
    * -------------------
    * Instead of precomputing both previous and next smaller indices,
    * we compute only the next smaller indices beforehand.
    *
    * The previous smaller index is calculated on the fly while traversing
    * the array using a monotonic increasing stack.
    *
    * This removes the need for an additional array for previous smaller
    * elements and reduces extra space usage.
    *
    * The stack naturally maintains the nearest smaller element to the left,
    * so we can retrieve the previous smaller index in O(1) time during
    * the main traversal.
    */
    public int largestRectangleArea(int[] heights) {
        int maxArea = 0;

        int[] nextSmallerIndices = findNextSmallerIndices(heights);
        Deque<Integer> stack = new ArrayDeque<>();

        for (int i = 0; i < heights.length; i++) {
            while (!stack.isEmpty() && heights[stack.peek()] >= heights[i]) {
                stack.pop();
            }

            int prevSmallerIndex = stack.isEmpty() ? -1 : stack.peek();

            int height = heights[i];

            int width = nextSmallerIndices[i] - prevSmallerIndex - 1;

            int area = height * width;

            maxArea = Math.max(maxArea, area);

            stack.push(i);
        }

        return maxArea;
    }

    private int[] findNextSmallerIndices(int[] heights) {
        int[] nextSmallerIndices = new int[heights.length];
        Deque<Integer> stack = new ArrayDeque<>();

        for (int i = heights.length - 1; i >= 0; i--) {

            while (!stack.isEmpty() && heights[stack.peek()] >= heights[i]) {
                stack.pop();
            }

            nextSmallerIndices[i] = stack.isEmpty() ? heights.length : stack.peek();

            stack.push(i);
        }

        return nextSmallerIndices;
    }
}


//Optimal Implementation 

class Solution {
    /*
     * Important Note on "Next Smaller Element"
     * ---------------------------------------
     * While popping, we treat the current index `i` as the next smaller element
     * for the popped bar. However, this is not strictly accurate in the case
     * of equal heights.
     *
     * For bars with equal height, expansion is still possible and does not
     * truly stop at the current index. A rectangle can extend across equal
     * height bars and only stops when a strictly smaller height is encountered.
     *
     * When the popped height and current height are equal, we are computing
     * an incorrect maximum possible area for that popped bar height. These areas do not
     * represent the maximum possible expansion for that height.
     *
     * However, the rightmost occurrence of that height remains in the stack
     * and eventually captures the full expansion (i.e., the correct maximum width)
     * when it is processed later.
     *
     * In other words:
     * - Earlier equal-height bars may compute incomplete areas
     * - The last occurrence of that height computes the full correct area
     */
    public int largestRectangleArea(int[] heights) {
        Deque<Integer> stack = new ArrayDeque<>();
        int maxArea = 0;

        for (int i = 0; i < heights.length; i++) {
            while (!stack.isEmpty() && heights[stack.peek()] >= heights[i]) {
                // Pop the index and compute the largest rectangle where this bar is the limiting height
                int barHeight = heights[stack.pop()];
                // The index of the previous smaller element for the popped 'barHeight' is now at the top of the stack
                int previousSmallerIndex = stack.isEmpty() ? -1 : stack.peek();
                // The current index `i` is the next smaller element index for the popped 'barHeight' as barHeight >= heights[i]
                int nextSmallerIndex = i;
                int width = nextSmallerIndex - previousSmallerIndex - 1;
                maxArea = Math.max(maxArea, barHeight * width);
            }
            // Push the current index onto the stack
            stack.push(i);
        }

        /*
         * Elements remaining in the stack do not have any next smaller bar
         * to their right. Therefore, their rectangle can extend until the
         * end of the histogram.
         *
         * Hence we treat the right boundary as heights.length and compute
         * the area accordingly.
         */
        while (!stack.isEmpty()) {
            // Pop the index and compute the largest rectangle where this bar is the limiting height
            int barHeight = heights[stack.pop()];
            // The index of the previous smaller element for the popped 'barHeight' is now at the top of the stack
            int previousSmallerIndex = stack.isEmpty() ? -1 : stack.peek();
            // As there is no smaller element to the right, set the next smaller element index to `heights.length` for the popped 'barHeight'.
            int nextSmallerIndex = heights.length;
            int width = nextSmallerIndex - previousSmallerIndex - 1;
            maxArea = Math.max(maxArea, barHeight * width);
        }

        return maxArea;
    }
}
