//Bruterforce Approach

class Solution {
    private static final int MOD = 1_000_000_007;

    public int sumSubarrayMins(int[] arr) {
        // Stores the total sum of minimums of all subarrays
        int totalMinSum = 0;

        // Generate all subarrays
        for (int start = 0; start < arr.length; start++) {
            for (int end = start; end < arr.length; end++) {
                // Find minimum for current subarray [start, end]
                int subarrayMin = findMinInSubarray(arr, start, end);

                // Add to total sum
                totalMinSum = (totalMinSum + (subarrayMin % MOD)) % MOD;
            }
        }

        return totalMinSum;
    }

    private int findMinInSubarray(int[] arr, int start, int end) {
        int min = Integer.MAX_VALUE;

        for (int i = start; i <= end; i++) {
            min = Math.min(min, arr[i]);
        }

        return min;
    }
}


//Improved Approach

class Solution {
    private static final int MOD = 1_000_000_007;

    public int sumSubarrayMins(int[] arr) {
        // Stores the total sum of minimum values across all subarrays
        int totalMinSum = 0;

        // Generate all subarrays
        for (int start = 0; start < arr.length; start++) {

            // Tracks the minimum for the current subarray starting at 'start'
            int currentMin = Integer.MAX_VALUE;

            // Extend the subarray to the right
            for (int end = start; end < arr.length; end++) {
                // Update minimum incrementally instead of recomputing
                currentMin = Math.min(currentMin, arr[end]);

                // Add contribution of current subarray
                totalMinSum = (totalMinSum + currentMin) % MOD;
            }
        }

        return totalMinSum;
    }
}


//Good Approach

class Solution {
    private static final int MOD = 1_000_000_007;

    /*
     * Intuition:
     * ----------
     * Finding the sum of minimums of all subarrays can be viewed differently.
     *
     * Instead of generating every possible subarray using (start, end),
     * we can think in terms of window sizes.
     *
     * Every subarray has a fixed size `k`, where k ranges from 1 to arr.length.
     *
     * So, the problem becomes:
     * - For each window size k :
     *   Find the minimum of every window of size k
     *   Sum all those minimums
     * - Add it to the overall total sum
     *
     * This is equivalent to considering all subarrays, but grouped by their size.
     *
     * Overall:
     * totalMinSum = sum of (minimum of all subarrays of size k) for all k
     */
    public int sumSubarrayMins(int[] arr) {
        int totalMinSum = 0;

        for (int windowSize = 1; windowSize <= arr.length; windowSize++) {
            totalMinSum = (totalMinSum + slidingWindowMinimumSum(arr, windowSize)) % MOD;
        }

        return totalMinSum;
    }

    private int slidingWindowMinimumSum(int[] arr, int k) {
        /*
         * Min Heap stores index of the element
         *
         * The heap is ordered by the VALUE at those indices in ascending order,
         * This ensures:
         * - The index at the top of the heap always corresponds
         *   to the minimum value in the current heap.
         *
         * Important:
         * - Indices are stored to identify and discard elements
         *   that fall out of the current window, i.e., elements
         *   that are part of previous windows.
         */
        Queue<Integer> minHeap = new PriorityQueue<>((idx1, idx2) -> {
            return Integer.compare(arr[idx1], arr[idx2]);
        });

        int windowStart = 0;
        int windowEnd = 0;
        int windowMinSum = 0;

        /*
        * Build the first window of size k.
        * Insert indices of all elements of the first window into the heap.
        */
        while (windowEnd < k) {
            minHeap.offer(windowEnd++);
        }

        // The index at the top of the heap corresponds to min value
        windowMinSum += arr[minHeap.peek()];

        /*
        * Slide the window:
        * - Move windowStart forward
        * - Add the new element's index entering the window to the heap
        */
        while (windowEnd < arr.length) {
            windowStart++;
            // Add the index of the new element entering the window
            minHeap.offer(windowEnd);
            // Get the minimum element for the current window
            windowMinSum += findWindowMin(minHeap, arr, windowStart);
            windowEnd++;
        }

        return windowMinSum;
    }

    private int findWindowMin(Queue<Integer> minHeap, int[] arr, int windowStart) {
        /*
         * The mix heap always keeps the index whose corresponding
         * value in the array is minimum among all stored indices.
         *
         * However, the index at the top of the heap may not
         * necessarily belong to the current window.
         * It could belong to a previous window.
         *
         * Therefore, before using the heap's top index,
         * we remove all indices that are less than windowStart,
         * because they fall outside the current window.
         *
         * Once all outdated indices are removed,
         * the index at the top of the heap is guaranteed
         * to correspond to the minimum element within the current window.
         *
         * ---------------------------------------------------------------
         * Key Takeaways:
         *
         * - The heap may store indices from older windows.
         * - This approach uses lazy removal for indices in the heap,
         *   indices are only removed when they impact the minimum value of the current window. 
         * - This guarantees correctness while avoiding unnecessary removals.
         */
        while (minHeap.peek() < windowStart) {
            minHeap.poll();
        }
        // The top index corresponds to the minimum in the current window
        return arr[minHeap.peek()];
    }
}


//Better Approach

class Solution {
    private static final int MOD = 1_000_000_007;

    public int sumSubarrayMins(int[] arr) {
        int totalMinSum = 0;

        for (int windowSize = 1; windowSize <= arr.length; windowSize++) {
            totalMinSum = (totalMinSum + slidingWindowMinimumSum(arr, windowSize)) % MOD;
        }

        return totalMinSum;
    }

    /*
    * Intuition:
    *
    * The deque always contains only those elements that can still become
    * the minimum in some future window.
    *
    * We keep elements that are larger but to the RIGHT of the current minimum
    * because they are potential candidates for the minimum when the current
    * minimum (at the front of the deque) slides out of the window.
    *
    * Why can we safely remove larger elements to the LEFT?
    *
    * If an element A is larger than a newer element B and A appears to the
    * left of B, then A can never be the minimum of any future window that
    * contains B.
    *
    * Reason:
    * - B is already smaller than A, so B will always dominate A in any window
    *   containing both.
    * - B enters later and stays longer in future windows, while A will slide
    *   out earlier.
    * - Even if a newer element enters, it will either replace B (if smaller)
    *   or B will remain the minimum.
    *
    * Therefore, for as long as the current minimum remains inside the window,
    * any larger element to its left is useless. When the minimum slides out,
    * the deque already contains the next best candidates from the right.
    */
    private int slidingWindowMinimumSum(int[] arr, int k) {
        Deque<Integer> increasingQueue = new ArrayDeque<>();

        int windowStart = 0;
        int windowEnd = 0;
        int windowMinSum = 0;

        // Process the first window separately
        while (windowEnd < k) {
            while (!increasingQueue.isEmpty() && arr[increasingQueue.peekLast()] >= arr[windowEnd]) {
                increasingQueue.pollLast();
            }
            increasingQueue.offerLast(windowEnd);
            windowEnd++;
        }

        // The minimum for the first window
        windowMinSum += arr[increasingQueue.peekFirst()];
        // Process the second window and all subsequent windows
        while (windowEnd < arr.length) {
            windowStart++;
            windowMinSum += findWindowMin(increasingQueue, arr, windowStart, windowEnd);
            windowEnd++;
        }

        return windowMinSum;
    }

    private int findWindowMin(Deque<Integer> increasingQueue, int[] arr, int windowStart, int windowEnd) {
        while (!increasingQueue.isEmpty() && arr[increasingQueue.peekLast()] >= arr[windowEnd]) {
            increasingQueue.pollLast();
        }

        increasingQueue.offerLast(windowEnd);

        /*
        * Since the sliding window moves by 1 position at each step,
        * the minimum element, which is always at the front of the deque
        * (because the deque is maintained in increasing order), is the
        * only element that can potentially fall out of the window.
        * 
        * As the left boundary of the window advances by 1 index, we need
        * to check if the element at the front of the deque is outside the
        * current window. If it is, we remove it to ensure the deque only
        * contains indices within the current window.
        * Ex: [5,3,4]
        */
        if (increasingQueue.peekFirst() < windowStart) {
            increasingQueue.pollFirst();
        }

        return arr[increasingQueue.peekFirst()];
    }
}


//Optimal Approach

/*
 * Instead of iterating over every subarray
 * and finding the minimum for each, then summing those minimums,
 * we can look at the problem differently.
 *
 * For each element, we ask:
 * "In how many subarrays does this element act as the minimum?"
 *
 * The formula to compute this is based on the count of elements
 * greater than the current element to its left and right
 * (without breaking the sequence). Let's define:
 *
 * Count of elements greater than arr[i] on the right side:
 *   = nextSmallerIndex(arr[i]) - i
 *
 * Count of elements greater than arr[i] on the left side:
 *   = i - prevSmallerIndex(arr[i])
 *
 * The number of subarrays where arr[i] is the minimum is:
 *   (nextSmallerIndex(arr[i]) - i) * (i - prevSmallerIndex(arr[i]))
 *
 * The total sum of minimums across all subarrays will be:
 *   sum += arr[i] * ((nextSmallerIndex(arr[i]) - i) * (i - prevSmallerIndex(arr[i])))
 *   for each element arr[i] in the array.
 *
 *
 * Example:
 * Consider the array: [7, 2, 4, 6, 3]
 *   Initial sum = 0
 *
 * Total subarrays where 7 is the minimum:
 *   - Subarrays: [7]
 *   - Count: 1
 *   - sum += (7 * 1)
 *
 * Total subarrays where 2 is the minimum:
 *   - Subarrays: [7, 2], [2], [2, 4, 6, 3], [2, 4, 6], [2, 4],
 *                [7, 2, 4, 6, 3], [7, 2, 4, 6], [7, 2, 4]
 *   - Count: 8
 *   - sum += (2 * 8)
 *
 * Total subarrays where 4 is the minimum:
 *   - Subarrays: [4], [4, 6]
 *   - Count: 2
 *   - sum += (4 * 2)
 *
 * Total subarrays where 6 is the minimum:
 *   - Subarrays: [6]
 *   - Count: 1
 *   - sum += (6 * 1)
 *
 * Total subarrays where 3 is the minimum:
 *   - Subarrays: [4, 6, 3], [6, 3], [3]
 *   - Count: 3
 *   - sum += (3 * 3)
 *
 * Final Total Sum = 45
 *
 *
 * => Corner case:
 *
 * Consider the array: [71, 55, 82, 55]
 *
 * Total subarrays where 71 is the minimum:
 *   - Subarrays: [71]
 *   - Count = 1
 *   - Contribution: 71 * 1 = 71
 *
 * Total subarrays where 55 is the minimum (first occurrence):
 *   - Subarrays: [71, 55], [55], [55, 82], [55, 82, 55],
 *                [71, 55, 82], [71, 55, 82, 55]
 *   - Count = 6
 *   - Contribution: 55 * 6 = 330
 *
 * Total subarrays where 82 is the minimum:
 *   - Subarrays: [82]
 *   - Count = 1
 *   - Contribution: 82 * 1 = 82
 *
 * Total subarrays where 55 is the minimum (second occurrence):
 *   - Subarrays: [71, 55, 82, 55], [55, 82, 55], [82, 55], [55]
 *   - Count = 4
 *   - Contribution: 55 * 4 = 220
 *
 * Issue with duplicate counting:
 * The subarrays [71, 55, 82, 55] and [55, 82, 55] are counted twice,
 * once for each occurrence of 55.
 *
 *
 * Handling Duplicates (Important):
 * -------------------------------
 * When the array contains duplicate values, care must be taken while
 * computing previous and next smaller elements.
 *
 * If we use the same condition on both sides:
 *
 * Case 1:
 *   Prev: >=
 *   Next: >=
 *   → Equal elements expand on both sides
 *   → Same subarray may be counted multiple times (overcounting)
 *
 * Case 2:
 *   Prev: >
 *   Next: >
 *   → Equal elements are not properly assigned
 *   → Some subarrays may not be counted (undercounting)
 *
 * Correct Approach:
 *   Use one strict and one non-strict comparison:
 *
 *   - One side: strictly smaller (>)
 *   - Other side: smaller or equal (>=)
 *
 * This ensures:
 *   - Each subarray is counted exactly once
 *   - Duplicate elements do not cause overlap in contribution
 *
 * This technique is essentially a tie-breaking strategy
 * for handling equal elements correctly.
 */
class Solution {
    private static final int MOD = 1000000007;

    public int sumSubarrayMins(int[] arr) {
        long totalMinSum = 0;

        int[] nextSmallerIndices = findNextSmallerIndices(arr);
        Deque<Integer> stack = new ArrayDeque<>();

        for (int i = 0; i < arr.length; i++) {
            while (!stack.isEmpty() && arr[stack.peek()] >= arr[i]) {
                stack.pop();
            }

            int prevSmallerIndex = stack.isEmpty() ? -1 : stack.peek();

            stack.push(i);

            long subarrayCount = (i - prevSmallerIndex) * (long) (nextSmallerIndices[i] - i);
            subarrayCount = subarrayCount % MOD;

            totalMinSum = totalMinSum + (arr[i] * subarrayCount) % MOD;
            totalMinSum = totalMinSum % MOD;
        }

        return (int) totalMinSum;
    }

    private int[] findNextSmallerIndices(int[] arr) {
        Deque<Integer> stack = new ArrayDeque<>();

        int[] nextSmallerIndices = new int[arr.length];

        for (int i = arr.length - 1; i >= 0; i--) {
            while (!stack.isEmpty() && arr[stack.peek()] > arr[i]) {
                stack.pop();
            }

            nextSmallerIndices[i] = stack.isEmpty() ? arr.length : stack.peek();
            stack.push(i);
        }

        return nextSmallerIndices;
    }
}
