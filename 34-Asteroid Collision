class Solution {
    /*
    * Cases:
    *
    * 1. Both asteroids move in the same direction:
    *    - Both positive (moving right) OR both negative (moving left)
    *    → No collision
    *
    * 2. First asteroid is negative (moving left),
    *    and second is positive (moving right)
    *    → No collision (they move away from each other)
    *
    * 3. First asteroid is positive (moving right),
    *    and second is negative (moving left)
    *    → Collision occurs
    *
    * Conclusion:
    * - Collision is possible only when:
    *   1. A right-moving asteroid (+) appears first
    *   2. It is followed by a left-moving asteroid (-)
    */
    public int[] asteroidCollision(int[] asteroids) {
        Deque<Integer> stack = new ArrayDeque<>();

        for (int asteroid : asteroids) {
            // Check for a possible collision: a right-moving asteroid (+ve) meets a left-moving asteroid (-ve)
            if (!stack.isEmpty() && (stack.peek() > 0 && asteroid < 0)) {
                // Case 1: Top (right-moving) asteroid is larger, current (left-moving) asteroid explodes
                if (Math.abs(stack.peek()) > Math.abs(asteroid)) {
                    continue;
                } else if (Math.abs(stack.peek()) == Math.abs(asteroid)) { // Case 2: Asteroids have equal size, both explode
                    stack.pop();
                } else if (Math.abs(stack.peek()) < Math.abs(asteroid)) { // Case 3: Current (left-moving) asteroid is larger, remove smaller (right-moving) asteroids from the stack
                    while (!stack.isEmpty() && (stack.peek() > 0 && (Math.abs(stack.peek()) < Math.abs(asteroid)))) {
                        stack.pop(); // Remove smaller right-moving asteroids from the stack
                    }

                    /*
                    * If the stack becomes empty after popping,
                    * the current (left-moving) asteroid survives and is added.
                    *
                    * OR if the top of the stack is also left-moving,
                    * add the current asteroid to the stack.
                    */
                    if (stack.isEmpty() || stack.peek() < 0) {
                        stack.push(asteroid);
                    } else if (stack.peek() > 0) { // If the top is a right-moving asteroid
                        if (stack.peek() == Math.abs(asteroid)) { // Case 3.1: Both asteroids are of the same size, both explode
                            stack.pop();
                        }
                        // Case 3.2: The top asteroid is larger, the current asteroid is destroyed 
                    }
                }
            } else {
                // If no collision is possible, push the current asteroid into the stack
                stack.push(asteroid);
            }
        }

        // Prepare the result array with the remaining asteroids in the stack
        int[] finalAsteroidState = new int[stack.size()];
        int index = stack.size() - 1;

        while (!stack.isEmpty()) {
            finalAsteroidState[index--] = stack.pop();
        }

        // Return the final state of the asteroids
        return finalAsteroidState;
    }
}
