/****************************************************************
 * 
 * Following is the class structure of the Node class:
 * 
 * static class Node
 * {
 * int data;
 * Node next;
 * Node()
 * {
 * this.data = 0;
 * this.next = null;
 * }
 * Node(int data)
 * {
 * this.data = data;
 * this.next = null;
 * }
 * Node(int data, Node next)
 * {
 * this.data = data;
 * this.next = next;
 * }
 * };
 * 
 * 
 *****************************************************************/

//Bruteforce Approach (Push operation : O(1) and Pop operation : O(n))

class SinglyLinkedList {
    // Pointer to the first node of the list
    private Node head;

    // Pointer to the last node of the list
    private Node tail;

    // Tracks number of nodes in the list
    private int size;

    public SinglyLinkedList() {
        head = tail = null;
        size = 0;
    }

    /**
     * Appends a new node at the end of the list.
     * This operation is used to implement the stack push operation.
     */
    public void append(int data) {
        Node node = new Node(data);

        // If list is empty, both head and tail point to new node
        if (head == null) {
            head = tail = node;
        } else {
            // Attach the new node after the current tail
            tail.next = node;
            // Update tail to the new node
            tail = tail.next;
        }

        size++;
    }

    /**
     * Removes the last node of the list.
     *
     * Since this is a singly linked list, we cannot directly
     * move backwards from tail to find the previous node.
     *
     * Therefore we must traverse from the head to find
     * the node just before the tail.
     *
     * This method is used to implement the stack pop operation.
     */
    public void removeLastNode() {
        if (size == 0) {
            return;
        }

        Node prev = null;
        Node node = head;

        // Traverse until we reach the last node while keeping track of the previous node
        while (node.next != null) {
            prev = node;
            node = node.next;
        }

        /*
         * If prev == null, it means there was only one node
         * in the list. Removing it makes the list empty.
         */
        if (prev == null) {
            head = tail = null;
        } else {
            // Disconnect the last node
            prev.next = null;
            // Update tail to the previous node
            tail = prev;
        }

        size--;
    }

    // Returns the number of nodes currently present in the list
    public int getSize() {
        return size;
    }

    /**
     * Returns the value stored at the tail node.
     *
     * Since the stack top corresponds to the last inserted element,
     * we treat the tail node as the top of the stack.
     */
    public int getTop() {
        if (isEmpty()) {
            return -1;
        }

        return tail.data;
    }

    // Checks whether the list is empty
    public boolean isEmpty() {
        return size == 0;
    }
}

public class Solution {
    static class Stack {
        // Underlying data structure used to store stack elements
        private SinglyLinkedList singlyLinkedList;

        Stack() {
            singlyLinkedList = new SinglyLinkedList();
        }

        // Returns the current number of elements in the stack
        int getSize() {
            return singlyLinkedList.getSize();
        }

        // Checks whether the stack is empty
        boolean isEmpty() {
            return singlyLinkedList.isEmpty();
        }

        /**
         * Inserts a new element at the end of the list,
         * which represents the top of the stack.
         */
        void push(int data) {
            singlyLinkedList.append(data);
        }

        /**     
         * Removes the last node of the list,
         * which represents the top element of the stack.
         */
        void pop() {
            singlyLinkedList.removeLastNode();
        }

        // Returns the element currently at the top of the stack 
        int getTop() {
            return singlyLinkedList.getTop();
        }
    }
}


// Optimal Approach (Push operation : O(1) and Pop operation : O(1))


class SinglyLinkedList {
    // Pointer to the first node of the list.
    // In this implementation, the head represents the top of the stack.
    private Node head;

    // Tracks the number of nodes currently present in the list
    private int size;

    public SinglyLinkedList() {
        head = null;
        size = 0;
    }

    /**
     * Inserts a new node at the front of the list.
     *
     * This operation is used to implement the stack push operation.
     *
     * Why front insertion?
     * --------------------
     * By treating the head of the list as the stack top,
     * we can perform push in O(1) time without traversing the list.
     */
    public void insertAtFront(int data) {
        Node node = new Node(data);

        // If the list is empty, the new node becomes the head
        if (getSize() == 0) {
            head = node;
        } else {
            // Insert the node before the current head
            node.next = head;
            head = node;
        }

        size++;
    }

    /**
     * Removes the first node of the list.
     *
     * Since the head represents the stack top,
     * removing the head corresponds to the stack pop operation.
     */
    public void removeFirstNode() {
        if (size == 0) {
            return;
        }

        // Move head to the next node
        head = head.next;

        size--;
    }

    // Returns the current number of elements in the list
    public int getSize() {
        return size;
    }

    /**
     * Returns the value stored at the head node.
     *
     * Since the head represents the stack top,
     * this method returns the current top element of the stack.
     */
    public int getTop() {
        if (isEmpty()) {
            return -1;
        }

        return head.data;
    }

    // Checks whether the list is empty
    public boolean isEmpty() {
        return size == 0;
    }
}

public class Solution {
    static class Stack {
        private SinglyLinkedList singlyLinkedList;

        Stack() {
            singlyLinkedList = new SinglyLinkedList();
        }

        // Returns the current number of elements in the stack
        int getSize() {
            return singlyLinkedList.getSize();
        }

        // Checks whether the stack is empty
        boolean isEmpty() {
            return singlyLinkedList.isEmpty();
        }

        /**
         * Push operation
         *
         * Inserts the element at the head of the list,
         * which represents the stack top.
         */
        void push(int data) {
            singlyLinkedList.insertAtFront(data);
        }

        /**
         * Pop operation
         *
         * Removes the head node,
         * which corresponds to removing the stack top.
         */
        void pop() {
            singlyLinkedList.removeFirstNode();
        }

        /**
         * Returns the element currently at the top
         * of the stack.
         */
        int getTop() {
            return singlyLinkedList.getTop();
        }
    }
}
