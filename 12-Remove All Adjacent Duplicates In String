//Bruteforce approach

class Solution {
    public String removeDuplicates(String str) {
        // Stack used to keep characters after removing adjacent duplicates
        Deque<Character> stack = new ArrayDeque<>();

        // Traverse the input string
        for (int i = 0; i < str.length(); i++) {
            char ch = str.charAt(i);

            /*
             * If stack is empty OR the current character
             * is different from the top of the stack,
             * push it onto the stack.
             */
            if (stack.isEmpty() || stack.peek() != ch) {
                stack.push(ch);
            } else {
                /*
                * If the current character matches the top of the stack,
                * it forms an adjacent duplicate pair.
                * Remove the previous character from the stack,
                * effectively deleting the duplicate pair.
                */
                stack.pop();
            }
        }

        // Build the final processed string from stack contents
        StringBuilder processedString = new StringBuilder();

        /*
         * Characters are stored in reverse order in the stack
         * due to the LIFO property, so we pop all characters
         * and append them to the StringBuilder.
         */
        while (!stack.isEmpty()) {
            processedString.append(stack.pop());
        }

        // Reverse the string to restore the original order
        return processedString.reverse().toString();
    }
}


//Optimal approach

class Solution {
    public String removeDuplicates(String str) {
        /*
         * Improvement over the previous stack-based approach:
         * Instead of using an explicit stack, we use StringBuilder itself as a stack.
         * The end of the StringBuilder represents the top of the stack.
         */
        StringBuilder processedString = new StringBuilder();

        // Traverse the input string
        for (int i = 0; i < str.length(); i++) {
            char ch = str.charAt(i);

            /*
             * If the StringBuilder is empty OR
             * the last character is different from the current character,
             * append the character (equivalent to stack push).
             */
            if (processedString.length() == 0 || processedString.charAt(processedString.length() - 1) != ch) {
                processedString.append(ch);
            } else {
                /*
                * If the last character is the same as the current character,
                * it forms an adjacent duplicate pair.
                *
                * Remove the last character (equivalent to stack pop),
                * effectively deleting the duplicate pair.
                */
                processedString.deleteCharAt(processedString.length() - 1);
            }
        }

        // The StringBuilder now contains the final string after removing duplicates
        return processedString.toString();
    }
}
