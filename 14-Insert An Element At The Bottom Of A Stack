//Using explicit stack (iterative approach)

public class Solution {
    public static Stack<Integer> pushAtBottom(Stack<Integer> stack, int x) {
        // Temporary stack used to reverse the order of elements
        Stack<Integer> auxStack = new Stack<>();

        // Move all elements from original stack to auxiliary stack
        while (!stack.isEmpty()) {
            auxStack.push(stack.pop());
        }

        // Insert the new element at the bottom
        stack.push(x);

        // Restore the original elements back on top of the new element
        while (!auxStack.isEmpty()) {
            stack.push(auxStack.pop());
        }

        return stack;
    }
}


//Using implicit stack (recursive approach)

public class Solution {
    public static Stack<Integer> pushAtBottom(Stack<Integer> stack, int value) {
        // Base case: if stack becomes empty, insert the element
        if (stack.isEmpty()) {
            stack.push(value);
            return stack;
        }

        // Remove the top element temporarily
        int topElement = stack.pop();

        // Recursively insert the element at the bottom
        pushAtBottom(stack, value);

        // Restore the removed element
        stack.push(topElement);

        return stack;
    }
}
