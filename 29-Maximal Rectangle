//Optimal Approach

class Solution {
    public int maximalRectangle(char[][] matrix) {
        int maxArea = 0;
        int[] heights = new int[matrix[0].length];

        for (int i = 0; i < matrix.length; i++) {
            for (int j = 0; j < matrix[0].length; j++) {
                if (matrix[i][j] == '1') {
                    heights[j] += 1;
                } else {
                    heights[j] = 0;
                }
            }

            maxArea = Math.max(maxArea, findLargestRectangleAreaInTheHistogram(heights));
        }

        return maxArea;
    }

    private int findLargestRectangleAreaInTheHistogram(int[] heights) {
        Deque<Integer> stack = new ArrayDeque<>();
        int maxArea = 0;

        for (int i = 0; i < heights.length; i++) {
            while (!stack.isEmpty() && heights[stack.peek()] >= heights[i]) {
                int barHeight = heights[stack.pop()];
                int previousSmallerIndex = stack.isEmpty() ? -1 : stack.peek();
                int nextSmallerIndex = i;
                int width = nextSmallerIndex - previousSmallerIndex - 1;
                maxArea = Math.max(maxArea, barHeight * width);
            }
            stack.push(i);
        }

        while (!stack.isEmpty()) {
            int barHeight = heights[stack.pop()];
            int previousSmallerIndex = stack.isEmpty() ? -1 : stack.peek();
            int nextSmallerIndex = heights.length;
            int width = nextSmallerIndex - previousSmallerIndex - 1;
            maxArea = Math.max(maxArea, barHeight * width);
        }

        return maxArea;
    }
}
